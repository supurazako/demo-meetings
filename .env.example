# App/signaling
# Required when the app is served through a tunnel/reverse proxy hostname.
VITE_ALLOWED_HOSTS=meet.example.com

# TURN server advertised to browsers.
# For a public VPS, use the VPS public IP or a DNS name that resolves to it.
VITE_TURN_URL=turn:203.0.113.10:3478
VITE_TURN_USERNAME=demo
VITE_TURN_CREDENTIAL=change-me

# coturn listen/relay configuration generated by npm scripts.
# VPS example:
TURN_HOST=0.0.0.0
TURN_EXTERNAL_IP=203.0.113.10
TURN_PORT=3478
TURN_MIN_PORT=50000
TURN_MAX_PORT=50100

# Local LAN example:
# TURN_HOST=192.0.2.10
# VITE_TURN_URL=turn:192.0.2.10:3478
