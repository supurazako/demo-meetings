{
  "name": "demo-meetings",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:signaling\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:signaling": "tsx server/signaling.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start:signaling": "node dist-server/signaling.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.468.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "ws": "^8.18.0",
    "tsx": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13"
  }
}
